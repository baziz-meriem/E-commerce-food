generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  DRIVER
  BRANCH_MANAGER
  ADMIN
  SUPER_ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum LoyaltyType {
  EARN
  REDEEM
  CASHBACK_ADJUST
}

enum PaymentMethod {
  COD
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  phone        String?
  role         Role     @default(CUSTOMER)
  branchId     String?
  branch       Branch?  @relation("BranchUsers", fields: [branchId], references: [id])
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  cartItems            CartItem[]
  orders               Order[]              @relation("CustomerOrders")
  loyaltyTransactions  LoyaltyTransaction[]
  driverProfile        DriverProfile?
  ordersAsDriver       Order[]              @relation("DriverOrders")
}

model Branch {
  id        String   @id @default(cuid())
  name      String
  address   String
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]           @relation("BranchUsers")
  driverProfiles  DriverProfile[]
  products        Product[]
  orders          Order[]
}

model Category {
  id        String    @id @default(cuid())
  nameAr    String
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id          String   @id @default(cuid())
  branchId    String
  branch      Branch   @relation(fields: [branchId], references: [id])
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  nameAr      String
  descriptionAr String @default("")
  price       Decimal
  imageUrl    String   @default("")
  stock       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cartItems CartItem[]
  orderItems OrderItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)

  @@unique([userId, productId])
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  userId          String
  user            User          @relation("CustomerOrders", fields: [userId], references: [id])
  branchId        String
  branch          Branch        @relation(fields: [branchId], references: [id])
  status          OrderStatus   @default(PENDING)
  subtotal        Decimal
  deliveryFee     Decimal       @default(0)
  loyaltyDiscount Decimal       @default(0)
  total           Decimal
  paymentMethod   PaymentMethod @default(COD)
  codCollected    Boolean       @default(false)
  deliveryAddress String
  deliveryPhone   String
  notes           String        @default("")
  driverId        String?
  driver          User?         @relation("DriverOrders", fields: [driverId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  items               OrderItem[]
  loyaltyTransactions LoyaltyTransaction[]
}

model OrderItem {
  id           String  @id @default(cuid())
  orderId      String
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product @relation(fields: [productId], references: [id])
  quantity     Int
  unitPrice    Decimal
  nameSnapshot String
}

model DriverProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleInfo String   @default("")
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id])
  createdAt   DateTime @default(now())
}

model LoyaltyTransaction {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      LoyaltyType
  points    Int
  balanceAfter Int
  description String    @default("")
  orderId   String?
  order     Order?      @relation(fields: [orderId], references: [id])
  createdAt DateTime    @default(now())
}

model Ad {
  id        String   @id @default(cuid())
  titleAr   String
  imageUrl  String   @default("")
  linkUrl   String   @default("")
  branchId  String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  startAt   DateTime?
  endAt     DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LoyaltySettings {
  id                    String @id @default("default")
  pointsPerCurrencyUnit Decimal @default(0.1)
  redeemPointsPerUnit   Decimal @default(100)
  minRedeemPoints       Int     @default(100)
}
